# =============================================================================
# Reg Demo — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -- Database (PostgreSQL from docker-compose) --------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=reg

# -- Cube (from docker-compose) ----------------------------------------------
CUBEJS_HOST=localhost
CUBEJS_PORT=4000
CUBEJS_API_SECRET=demo-secret
